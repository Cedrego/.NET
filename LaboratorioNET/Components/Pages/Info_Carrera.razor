@page "/info_carreras"
@rendermode InteractiveServer

@using LaboratorioNET.Entities
@using LaboratorioNET.Services
@using MongoDB.Driver
@inject MongoDbService MongoDb
@inject NavigationManager Navigation

<PageTitle>Información Carreras </PageTitle>

<style>
 .background-container {
        background-image: url('images/2.jpg');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
        min-height: 100vh;
        width: 100%;
        display: flex;
        justify-content: center;
        align-items: center;
    }

    .page {
        display: flex;
        justify-content: center;
        align-items: center;
        min-height: 100vh;
        background-color: #f0f0f0;
    }

    .container-box {
        display: flex;
        background-color: #efefef;
        border: 2px solid #79c9e0;
        border-radius: 20px;
        width: 95%;
        max-width: 1200px;
        height: 90vh;
        box-shadow: 0 2px 6px rgba(0,0,0,0.1);
    }

    .sidebar {
        background-color: #79c9e0;
        border-right: 2px solid #79c9e0;
        border-radius: 20px 0 0 20px;
        width: 25%;
        min-width: 220px;
        text-align: center;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 22px;
        font-weight: bold;
        color: #fff;
    }
    
    .content {
        flex: 1;
        background-color: #efefef;
        border-radius: 0 20px 20px 0;
        padding: 40px;
        overflow-y: auto;
    }

    .title {
        text-align: center;
        color: #333;
        margin-bottom: 30px;
    }
    
    .info-table {
        width: 100%;
        border-collapse: collapse;
        margin-top: 20px;
    }

    .info-table th, .info-table td {
        border: 1px solid #ccc;
        padding: 8px;
        text-align: left;
    }

    .info-table th {
        background-color: #e0e0e0;
    }
</style>

<div class="background-container">
    <div class="container-box">
        <aside class="sidebar">
            <h2>SportEvent<br />Manager,</h2>
        </aside>

        <main class="content">
            <button @onclick="NavigateToHome" class="btn btn-secondary mb-4" style="display:flex; align-items:center;">
                <span class="oi oi-arrow-left" aria-hidden="true" style="margin-right: 5px;"></span>
                Volver
            </button>

            <h1 class="title">Información de Carrera</h1>

            <div class="info-section">
                <p><strong>Seleccionar Carrera:</strong></p>
                <select @bind="selectedCarreraId" @bind:after="OnCarreraSelected" class="form-control">
                    <option value="">-- Seleccione una Carrera --</option>
                    @if (carreras != null)
                    {
                        @foreach (var carrera in carreras)
                        {
                            <option value="@carrera.IdCarrera">@carrera.Nombre</option>
                        }
                    }
                </select>
            </div>

            @if (selectedCarrera != null)
            {
                <h3 class="mt-4">@selectedCarrera.Nombre</h3>
                <p><strong>Fecha Inicio:</strong> @selectedCarrera.FechaInicio.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</p>
                <p><strong>Lugar:</strong> @selectedCarrera.LugarSalida</p>
                <p>
                    <strong>Estado:</strong> 
                    @if (selectedCarrera.Terminada)
                    {
                        <span style="color: green; font-weight: bold;">✓ TERMINADA</span>
                    }
                    else
                    {
                        <span style="color: orange; font-weight: bold;">⏱️ EN PROGRESO</span>
                    }
                </p>

                <h4 class="mt-4">Corredores Registrados:</h4>
                <table class="info-table">
                    <thead>
                        <tr>
                            <th>Dorsal</th>
                            <th>Corredor</th>
                            <th>Tiempos Registrados</th>
                            <th>Progreso</th>
                            <th>Tiempo Total</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (corredorRegistros.Any())
                        {
                            @foreach (var registro in corredorRegistros)
                            {
                                var progreso = (registro.Tiempos.Count * 100) / selectedCarrera.CantSecciones;
                                var completado = registro.Tiempos.Count == selectedCarrera.CantSecciones;
                                
                                <tr style="@(completado ? "background-color: #e8f5e9;" : "")">
                                    <td>@registro.NumDorsal</td>
                                    <td>@GetCorredorNombre(registro.IdentifiCorredor)</td>
                                    <td>
                                        @FormatTiempos(registro.Tiempos)
                                    </td>
                                    <td>
                                        <div style="width: 100px; background-color: #ddd; border-radius: 5px; overflow: hidden;">
                                            <div style="width: @progreso%; background-color: @(completado ? "#4caf50" : "#ff9800"); height: 20px; display: flex; align-items: center; justify-content: center; color: white; font-size: 12px; font-weight: bold;">
                                                @progreso%
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        @if (completado)
                                        {
                                            <span style="color: green;">✓ @FormatTiempoTotal(registro.Tiempos)</span>
                                        }
                                        else
                                        {
                                            <span style="color: orange;">⏱️ @registro.Tiempos.Count/@selectedCarrera.CantSecciones</span>
                                        }
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr><td colspan="5" class="text-center">No hay corredores registrados para esta carrera.</td></tr>
                        }
                    </tbody>
                </table>
            }
            else if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert alert-danger mt-4">@errorMessage</div>
            }

        </main>
    </div>
</div>

@code {

    private List<Carrera> carreras = new List<Carrera>();
    private string selectedCarreraId = string.Empty;
    private Carrera? selectedCarrera;
    private List<Registro> corredorRegistros = new List<Registro>();
    private Dictionary<string, Corredor> corredoresMap = new Dictionary<string, Corredor>();
    private string errorMessage = string.Empty;
    private bool isLoading = true;
    private bool isCorredoresLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadCarrerasAsync();
    }

    private async Task LoadCarrerasAsync()
    {
        try
        {
            isLoading = true;
            
            // Cargar todas las carreras desde MongoDB
            carreras = await MongoDb.Carreras
                .Find(Builders<Carrera>.Filter.Empty)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar carreras: {ex.Message}";
            Console.WriteLine($"[ERROR MONGODB]: {ex}");
        }
        finally
        {
            isLoading = false;
        }
    }

    private void NavigateToHome()
    {
        Navigation.NavigateTo("/");
    }
    
    private async Task OnCarreraSelected()
    {
        errorMessage = string.Empty;
        selectedCarrera = null;
        corredorRegistros = new List<Registro>();
        corredoresMap.Clear();

        if (string.IsNullOrEmpty(selectedCarreraId))
        {
            StateHasChanged();
            return;
        }

        // 1. Buscar la carrera seleccionada por IdCarrera
        selectedCarrera = carreras.FirstOrDefault(c => c.IdCarrera == selectedCarreraId);

        if (selectedCarrera != null)
        {
            await LoadCorredoresYRegistrosAsync();
        }
        StateHasChanged();
    }

    private async Task LoadCorredoresYRegistrosAsync()
    {
        try
        {
            isCorredoresLoading = true;
            
            // 2. Cargar registros (Tiempos) para la carrera seleccionada
            var filter = Builders<Registro>.Filter.Eq(r => r.IDCarrera, selectedCarreraId);
            
            corredorRegistros = await MongoDb.Registros
                .Find(filter)
                .ToListAsync();

            // 3. Cargar información de corredores (solo los IDs que están en los registros)
            var corredorIds = corredorRegistros.Select(r => r.IdentifiCorredor).Distinct().ToList();
            
            if (corredorIds.Any())
            {
                // Consulta optimizada: obtener todos los corredores en una sola query
                var filterCorredores = Builders<Corredor>.Filter.In(c => c.DocumentoIdentidad, corredorIds);
                var corredores = await MongoDb.Corredores
                    .Find(filterCorredores)
                    .ToListAsync();
                
                // Construir el diccionario
                foreach (var corredor in corredores)
                {
                    corredoresMap[corredor.DocumentoIdentidad] = corredor;
                }
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Error al cargar corredores: {ex.Message}";
            Console.WriteLine($"[ERROR MONGODB]: {ex}");
        }
        finally
        {
            isCorredoresLoading = false;
        }
    }

    private string GetCorredorNombre(string idCorredor)
    {
        return corredoresMap.ContainsKey(idCorredor) ? corredoresMap[idCorredor].Nombre : idCorredor;
    }

    private string FormatTiempos(List<DateTime> tiempos)
    {
        if (tiempos == null || !tiempos.Any())
        {
            return "N/A";
        }

        var startTime = selectedCarrera?.FechaInicio.ToLocalTime();
        if (startTime == null) return "Error: Sin inicio";

        var formattedTimes = new List<string>();
        
        // Recalcular el tiempo transcurrido respecto a la hora de inicio (startTime)
        for (int i = 0; i < tiempos.Count; i++)
        {
            // MongoDB almacena DateTime directamente
            var timeValue = tiempos[i].ToLocalTime();
            var elapsed = timeValue - startTime.Value;
            
            // Formatear: S[i+1]: HH:mm:ss.fff
            formattedTimes.Add($"S{i + 1}: {elapsed.Hours:D2}:{elapsed.Minutes:D2}:{elapsed.Seconds:D2}.{elapsed.Milliseconds:D3}");
        }

        return string.Join(" | ", formattedTimes);
    }

    /// Calcula el tiempo total del corredor.
    private string FormatTiempoTotal(List<DateTime> tiempos)
    {
        if (tiempos == null || !tiempos.Any())
        {
            return "N/A";
        }

        var startTime = selectedCarrera?.FechaInicio.ToLocalTime();
        if (startTime == null) return "Error: Sin inicio";

        // El tiempo total es la diferencia entre el ÚLTIMO tiempo registrado y la hora de inicio.
        var finalTime = tiempos.Last().ToLocalTime();
        var totalElapsed = finalTime - startTime.Value;

        // Formato total: HH:mm:ss.fff
        return $"{totalElapsed.Hours:D2}:{totalElapsed.Minutes:D2}:{totalElapsed.Seconds:D2}.{totalElapsed.Milliseconds:D3}";
    }
}